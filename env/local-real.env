# Local dev with no API mocking — talks to real pact-auth + pact-gateway.
# Easiest: run `make dev` in .github-private/dev-stack (brings up everything).
# Manual: see `make manual` in that same Makefile.

NEXT_PUBLIC_API_MOCKING=disabled
PACT_GATEWAY_URL=http://localhost:8110
PACT_BENCHMARK_URL=http://localhost:10093
PACT_AUTH_GRPC_ADDR=http://localhost:9090
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_VERCEL_ENVIRONMENT="development"
NEXT_PUBLIC_MSW_DEBUG=false
