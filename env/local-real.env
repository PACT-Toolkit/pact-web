# Local dev with no API mocking — talks to real pact-auth + pact-gateway.
# Bring up dependencies first:
#   cd ../pact-auth && make compose-up && make dev
# Then in pact-web:
#   pnpm run dev:real

NEXT_PUBLIC_API_MOCKING=disabled
PACT_GATEWAY_URL=http://localhost:8080
PACT_AUTH_GRPC_ADDR=http://localhost:9090
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_VERCEL_ENVIRONMENT="development"
NEXT_PUBLIC_MSW_DEBUG=false
