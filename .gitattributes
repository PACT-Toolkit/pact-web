# Pin generated files to LF line endings regardless of a developer's local
# core.autocrlf setting. Without this, Windows checkouts (autocrlf=true)
# convert these files to CRLF on checkout, and re-running codegen (which
# always writes LF) produces phantom line-ending diffs. (PACT-370)

# Orval REST client + buf-generated proto stubs (pnpm rest:codegen / pnpm proto:gen)
src/__codegen__/** text eol=lf

# Orval config file - regenerated in place by scripts/rest-codegen.mjs
orval.config.ts text eol=lf

# MSW service worker, regenerated by `pnpm msw:init`
public/mockServiceWorker.js text eol=lf
public/assets/scripts/mockServiceWorker.js text eol=lf
