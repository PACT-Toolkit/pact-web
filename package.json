{
  "name": "pact-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "bash scripts/postinstall.sh",
    "build": "next build",
    "build:mock": "env-cmd -f ./env/local.env next build",
    "build:local": "pnpm run build:mock && pnpm run start:mock",
    "dev": "vercel env pull && env-cmd -f ./.env.local next dev --turbopack",
    "dev:mock": "env-cmd -f ./env/local.env next dev --turbopack",
    "dev:real": "env-cmd -f ./env/local-real.env next dev --turbopack",
    "dev:https": "env-cmd -f ./env/local.env next dev --turbopack --experimental-https",
    "dev:https:real": "env-cmd -f ./env/local-real.env next dev --turbopack --experimental-https",
    "dev:lan": "bash scripts/dev-lan.sh",
    "dev:https:lan": "bash scripts/dev-lan.sh --https",
    "start:mock": "env-cmd -f ./env/local.env next start",
    "start": "pnpm run dev:mock",
    "pw:run": "playwright test",
    "pw:open": "playwright test --ui",
    "pw:e2e": "playwright test --config playwright.e2e.config.ts",
    "pw:e2e:ui": "playwright test --config playwright.e2e.config.ts --ui",
    "test": "TZ=CET vitest run",
    "test:watch": "TZ=CET vitest",
    "lint": "pnpm run lint:typescript && pnpm run lint:eslint",
    "lint:eslint": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js --rule 'import-x/no-cycle: [error, { ignoreExternal: true, maxDepth: 4 }]'",
    "lint:eslint:staged": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js --cache --no-warn-ignored",
    "lint:typescript": "tsc --noEmit",
    "msw:init": "npx msw init ./public --no-save",
    "prebuild": "next telemetry disable",
    "prepare": "husky",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "rest:codegen": "node scripts/rest-codegen.mjs",
    "proto:gen": "buf generate",
    "api:update": "node scripts/api-download.mjs && pnpm run rest:codegen",
    "vercel:link": "vercel link"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.0",
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-node": "2.1.1",
    "@hookform/resolvers": "5.2.2",
    "@vercel/analytics": "2.0.1",
    "axios": "1.16.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "1.14.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.75.0",
    "sharp": "0.34.5",
    "swr": "2.4.1",
    "tailwind-merge": "3.6.0",
    "uuid": "14.0.0",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@bufbuild/buf": "1.69.0",
    "@bufbuild/protoc-gen-es": "2.12.0",
    "@faker-js/faker": "10.4.0",
    "@playwright/test": "1.59.1",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.12.4",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.15",
    "@vitejs/plugin-react": "6.0.2",
    "env-cmd": "11.0.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-boundaries": "6.0.2",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "msw": "2.14.5",
    "orval": "8.9.1",
    "otpauth": "9.5.1",
    "pg": "8.20.0",
    "prettier": "3.8.3",
    "swagger2openapi": "7.0.8",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "unzip-stream": "0.3.4",
    "vercel": "53.4.0",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  }
}
