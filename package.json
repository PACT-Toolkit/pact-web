{
  "name": "pact-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "bash scripts/postinstall.sh",
    "build": "next build",
    "build:mock": "env-cmd -f ./env/local.env next build",
    "build:local": "pnpm run build:mock && pnpm run start:mock",
    "dev": "vercel env pull && env-cmd -f ./.env.local next dev --turbopack",
    "dev:mock": "env-cmd -f ./env/local.env next dev --turbopack",
    "start:mock": "env-cmd -f ./env/local.env next start",
    "start": "pnpm run dev:mock",
    "pw:run": "playwright test",
    "pw:open": "playwright test --ui",
    "test": "TZ=CET vitest run",
    "test:watch": "TZ=CET vitest",
    "lint": "pnpm run lint:typescript && pnpm run lint:eslint",
    "lint:eslint": "NODE_OPTIONS='--max-old-space-size=8192' eslint --rule 'import-x/no-cycle: [error, { ignoreExternal: true, maxDepth: 4 }]'",
    "lint:typescript": "tsc --noEmit",
    "msw:init": "npx msw init ./public --no-save",
    "prebuild": "next telemetry disable",
    "prepare": "husky",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "rest:codegen": "node scripts/rest-codegen.mjs",
    "api:update": "pnpm run rest:codegen",
    "vercel:link": "vercel link"
  },
  "dependencies": {
    "@hookform/resolvers": "3.10.0",
    "@radix-ui/react-slot": "1.2.4",
    "axios": "1.15.0",
    "better-auth": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "2.30.0",
    "lucide-react": "^0.469.0",
    "next": "16.1.6",
    "radix-ui": "1.4.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.69.0",
    "sharp": "0.34.5",
    "swr": "2.3.8",
    "tailwind-merge": "^2.6.0",
    "uuid": "11.1.0",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@faker-js/faker": "8.4.1",
    "@playwright/test": "1.58.2",
    "@svgr/webpack": "7.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.17.1",
    "@types/react": "18.3.12",
    "@vitejs/plugin-react": "5.1.4",
    "env-cmd": "10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-boundaries": "6.0.1",
    "eslint-plugin-import-x": "^4.15.2",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jsdom": "28.1.0",
    "lint-staged": "15.4.3",
    "msw": "2.12.4",
    "openapi-typescript": "7.10.1",
    "orval": "7.17.2",
    "prettier": "3.7.4",
    "swagger2openapi": "7.0.8",
    "tailwindcss": "^4.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "unzip-stream": "0.3.4",
    "vercel": "50.1.3",
    "vite": "7.3.2",
    "vitest": "4.0.18"
  }
}
